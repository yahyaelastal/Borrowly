##############################################
# Borrowly – Spring Boot / Maven / Docker
# Complete .gitignore
##############################################

# ──────────────────────────────────────────
# Maven build output
# ──────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.properties
.mvn/wrapper/maven-wrapper.jar
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# ──────────────────────────────────────────
# Spring Boot / application config secrets
# ──────────────────────────────────────────
# Never commit secrets – use env vars or a vault instead
src/main/resources/application-local.properties
src/main/resources/application-local.yml
src/main/resources/application-secret*.properties
src/main/resources/application-secret*.yml
*.env
.env
.env.*
!.env.example

# ──────────────────────────────────────────
# Lombok generated sources (annotation processing)
# ──────────────────────────────────────────
.apt_generated/
.apt_generated_tests/

# ──────────────────────────────────────────
# Java / JVM
# ──────────────────────────────────────────
*.class
*.log
*.ctxt
.mtj.tmp/
hs_err_pid*
replay_pid*

# ──────────────────────────────────────────
# H2 embedded database files
# ──────────────────────────────────────────
*.db
*.mv.db
*.trace.db
*.lock.db

# ──────────────────────────────────────────
# Docker local volumes / data
# ──────────────────────────────────────────
postgres-data/
docker-volumes/
.docker/

# ──────────────────────────────────────────
# IntelliJ IDEA
# ──────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
.idea_modules/

# ──────────────────────────────────────────
# Eclipse / STS (Spring Tool Suite)
# ──────────────────────────────────────────
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/
.apt_generated

# ──────────────────────────────────────────
# NetBeans
# ──────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ──────────────────────────────────────────
# VS Code
# ──────────────────────────────────────────s
.vscode/
*.code-workspace

# ──────────────────────────────────────────
# OS-generated files
# ──────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ──────────────────────────────────────────
# Logs & temp files
# ──────────────────────────────────────────
logs/
*.log
*.log.*
*.tmp
*.swp
*.swo

# ──────────────────────────────────────────
# Node / npm (if any frontend tooling exists)
# ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ──────────────────────────────────────────
# Test / coverage reports
# ──────────────────────────────────────────
/test-output/
/surefire-reports/
/failsafe-reports/
target/site/

# ──────────────────────────────────────────
# HELP.md (auto-generated by Spring Initializr)
# ──────────────────────────────────────────
HELP.md
